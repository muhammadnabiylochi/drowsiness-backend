# ============================================
# Drowsiness Detection System — Configuration
# ============================================

# --- Camera ---
CAM_SOURCE=0                    # 0=webcam, rtsp://user:pass@ip/path, /path/video.mp4
CAM_WIDTH=640
CAM_HEIGHT=480
CAM_FPS=30
CAM_FLIP_HORIZONTAL=true

# --- Detection Thresholds (from paper) ---
DET_EAR_THRESHOLD=0.22          # Eye Aspect Ratio threshold (Eq.4)
DET_MAR_THRESHOLD=0.55          # Mouth Aspect Ratio threshold
DET_DROWSY_FRAME_THRESHOLD=15   # Consecutive closed-eye frames → DROWSY
DET_YAWN_FRAME_THRESHOLD=10     # Consecutive yawn frames → YAWNING
DET_MAX_BLINK_FRAMES=8          # Max frames for normal blink
DET_PERCLOS_WINDOW_SEC=60       # PERCLOS calculation window
DET_PERCLOS_THRESHOLD=0.4       # PERCLOS > 0.4 = high risk

# --- Alerts ---
ALERT_ENABLED=true
ALERT_SOUND_FILE=               # Path to .wav alert sound
ALERT_COOLDOWN_SEC=5.0
ALERT_LOG_FILE=logs/drowsiness_events.log
ALERT_WEBHOOK_URL=              # Optional: https://your-fleet-api.com/alert

# --- Web Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_DEBUG=false

# --- Axis P1367 Camera Example ---
# CAM_SOURCE=rtsp://root:password@192.168.1.100/axis-media/media.amp?videocodec=h264&resolution=640x480
